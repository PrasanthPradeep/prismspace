{
  "name": "prismspace",
  "version": "1.0.0",
  "description": "Prism Space browser extension",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt -b chrome --mv3",
    "dev:chrome": "wxt -b chrome --mv3",
    "dev:firefox": "wxt -b firefox --mv3",
    "build": "pnpm run build:chrome && pnpm run build:firefox",
    "build:chrome": "wxt build -b chrome --mv3",
    "build:firefox": "wxt build -b firefox --mv3",
    "zip": "pnpm run zip:chrome && pnpm run zip:firefox",
    "zip:chrome": "wxt zip -b chrome --mv3",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@wxt-dev/module-react": "^1.1.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "wxt": "^0.20.6"
  },
  "packageManager": "pnpm@11.1.3"
}
