# ─── AI Provider ─────────────────────────────────────────
# Which provider to try first: "gemini", "groq", or "groq-proxy"
AI_PROVIDER=gemini

# Optional comma-separated fallback order.
AI_FALLBACK_PROVIDERS=groq,groq-proxy

# ─── Google Gemini ────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ─── Groq ─────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=openai/gpt-oss-120b

# Uses the same Azure Groq proxy as the legacy floating Dev Space tools.
# Leave unset to use the built-in Prism proxy URL.
GROQ_PROXY_URL=

# ─── Server ───────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ─── Security ────────────────────────────────────────────
# Shared secret sent by the extension in X-Prism-Secret header.
# Set this to a random 32+ character string.
EXTENSION_SECRET=change-me-to-a-random-secret-string

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use your actual extension IDs from the browser's extension management page.
# Chrome: chrome-extension://<extension-id>
# Firefox: moz-extension://<extension-id>
ALLOWED_ORIGINS=chrome-extension://YOUR_CHROME_EXTENSION_ID,moz-extension://YOUR_FIREFOX_EXTENSION_ID

# ─── Rate Limiting ────────────────────────────────────────
# Max requests per IP per minute window
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
